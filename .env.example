# 数据库（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=diet_tracking

# 服务端口
PORT=3000

# 定时任务：是否启用每日汇总（0 否 1 是）
CRON_DAILY_SUMMARY_ENABLED=1

# v4.0 JWT 鉴权（必填，用于登录签发 Token）
JWT_SECRET=your-secret-key-change-in-production

# AI 分析（可选，不配置则使用规则引擎降级报告）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
